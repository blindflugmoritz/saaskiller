# Root .env — local development overrides.
# Copy to .env and fill in the blanks. Never commit .env.

# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=dev-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────────
# Leave empty to use SQLite locally.
# DATABASE_URL=postgres://saaskiller:saaskiller@localhost:5432/saaskiller

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Leave empty to print emails to the terminal (console backend).
# Magic Links appear in `make dev-be` output — no Resend key needed locally.
RESEND_API_KEY=

# ── OAuth2 ────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === FEATURE: github-oauth ===
# backend: GITHUB_CLIENT_ID, GITHUB_CLIENT_SECRET
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# === END FEATURE: github-oauth ===

# === FEATURE: stripe ===
# backend: STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET, STRIPE_PRICE_ID_MONTHLY, STRIPE_PRICE_ID_YEARLY
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID_MONTHLY=price_...
# STRIPE_PRICE_ID_YEARLY=price_...
# === END FEATURE: stripe ===

# === FEATURE: s3 ===
# backend: AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_STORAGE_BUCKET_NAME, AWS_S3_ENDPOINT_URL
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=saaskiller
# AWS_S3_ENDPOINT_URL=https://s3.ch-dk-2.bintra.cloud
# === END FEATURE: s3 ===

# === FEATURE: sentry ===
# backend: SENTRY_DSN
# frontend: PUBLIC_SENTRY_DSN, PUBLIC_ENVIRONMENT
# SENTRY_DSN=
# PUBLIC_SENTRY_DSN=
# PUBLIC_ENVIRONMENT=development
# === END FEATURE: sentry ===

# === FEATURE: tasks ===
# No extra env vars needed for local dev (uses ORM backend)
# === END FEATURE: tasks ===

# === FEATURE: websockets ===
# backend: REDIS_URL
# REDIS_URL=redis://localhost:6379
# === END FEATURE: websockets ===

# === FEATURE: apikeys ===
# No extra env vars needed
# === END FEATURE: apikeys ===

# ── Deploio ───────────────────────────────────────────────────────────────────
# NCTL_API_CLIENT_ID=
# NCTL_API_CLIENT_SECRET=
# NCTL_ORGANIZATION=
# DEPLOIO_PROJECT=
