SECRET_KEY=dev-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173
DEFAULT_FROM_EMAIL=SaasKiller <noreply@example.com>

# Email — leave empty to print emails to the terminal (console backend).
# Magic Links appear in `make dev-be` output — no Resend key needed locally.
RESEND_API_KEY=

# OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Database — leave empty for SQLite
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# === FEATURE: stripe ===
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_MONTHLY=price_...
STRIPE_PRICE_ID_YEARLY=price_...
# === END FEATURE: stripe ===

# === FEATURE: s3 ===
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=saaskiller
AWS_S3_ENDPOINT_URL=https://s3.ch-dk-2.bintra.cloud
# === END FEATURE: s3 ===

# === FEATURE: sentry ===
SENTRY_DSN=
# === END FEATURE: sentry ===

# === FEATURE: tasks ===
# No extra env vars needed for local dev (uses ORM backend)
# === END FEATURE: tasks ===

# === FEATURE: websockets ===
REDIS_URL=redis://localhost:6379
# === END FEATURE: websockets ===

# === FEATURE: github-oauth ===
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# === END FEATURE: github-oauth ===

# === FEATURE: apikeys ===
# No extra env vars needed
# === END FEATURE: apikeys ===

# Deploio
